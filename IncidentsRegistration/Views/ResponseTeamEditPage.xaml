<Page x:Class="IncidentsRegistration.Views.ResponseTeamEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F0F2F5" Title="Конфигурация группы">

    <Page.Resources>
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#8B959E"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="1" CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,25">
            <Button Content="← Назад к списку" Command="{Binding BackCommand}" 
                    Background="Transparent" BorderThickness="0" Foreground="#8B959E" 
                    HorizontalAlignment="Left" Cursor="Hand" Margin="0,0,0,10"/>
            <TextBlock Text="КОНФИГУРАЦИЯ ГРУППЫ" FontSize="11" FontWeight="Bold" Foreground="#8B959E"/>
            <TextBlock Text="{Binding PageHeader}" FontSize="28" FontWeight="SemiBold" Foreground="#2D3436"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="White" CornerRadius="20" Padding="25" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.06"/>
                    </Border.Effect>
                    <StackPanel>
                        <Border Background="{StaticResource PrimaryGreen}" CornerRadius="10" Padding="12,5" HorizontalAlignment="Left" Margin="0,0,0,15">
                            <TextBlock Text="ОБЩИЕ СВЕДЕНИЯ" Foreground="#2D4A3E" FontWeight="Bold" FontSize="10"/>
                        </Border>

                        <TextBlock Text="Название команды" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding CurrentTeam.NameTeam}" Height="40"/>

                        <TextBlock Text="Количество сотрудников" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding CurrentTeam.NumberOfPeople}" Height="40" Width="120" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="20" Padding="25" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.06"/>
                    </Border.Effect>
                    <StackPanel>
                        <Border Background="{StaticResource SecondaryBlue}" CornerRadius="10" Padding="12,5" HorizontalAlignment="Left" Margin="0,0,0,15">
                            <TextBlock Text="ДАННЫЕ РУКОВОДИТЕЛЯ" Foreground="#4A90E2" FontWeight="Bold" FontSize="10"/>
                        </Border>

                        <TextBlock Text="Фамилия" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding CurrentTeam.DirectorLastName}" Height="40"/>

                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Имя" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding CurrentTeam.DirectorFirstName}" Height="40"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Отчество" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding CurrentTeam.DirectorPatronymic}" Height="40"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="2" Content="Сохранить изменения" Command="{Binding SaveCommand}" 
                Height="50" Background="{StaticResource SecondaryBlue}" Foreground="White" 
                FontWeight="Bold" FontSize="14">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="12"/>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</Page>