<Page x:Class="IncidentsRegistration.Views.IncidentSubjectsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:IncidentsRegistration.Views"
      Background="#F0F2F5" Title="Участники инцидента">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="СОСТАВ ИНЦИДЕНТА" FontSize="11" FontWeight="Bold" Foreground="#8B959E"/>
            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <Border Background="{StaticResource PrimaryGreen}" Width="8" Height="30" CornerRadius="4" Margin="0,0,15,0"/>
                <TextBlock Text="Участники по делу" FontSize="28" FontWeight="SemiBold" Foreground="#2D3436"/>
            </StackPanel>
        </StackPanel>

        <ListBox Grid.Row="1" Margin="0,20,0,0"
                 ItemsSource="{Binding Incidents}"
                 SelectedItem="{Binding SelectedIncident}"
                 Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border x:Name="CardBorder" Background="White" CornerRadius="15" Margin="0,0,10,12" Padding="18">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" Opacity="0.05"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="1.5*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <Border Background="{StaticResource SecondaryBlue}" CornerRadius="8" Padding="10,4">
                                    <TextBlock Text="{Binding RegistrationTime, StringFormat=\{0:HH:mm\}}" FontWeight="Bold" Foreground="#4A90E2" HorizontalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding RegistrationDate, StringFormat=\{0:dd.MM.yy\}}" FontSize="10" Foreground="#ADB5BD" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="20,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding TypeOfIncident}" FontSize="16" FontWeight="Bold" Foreground="#2D3436"/>
                                <TextBlock Text="{Binding IdIncident, StringFormat='ID: {0}'}" Foreground="#8B959E" FontSize="11"/>
                            </StackPanel>

                            <Border Grid.Column="2" Background="#F8F9FA" CornerRadius="10" Padding="10" VerticalAlignment="Center">
                                <StackPanel>
                                    <TextBlock Text="ЗАРЕГИСТРИРОВАНЫ:" FontSize="9" FontWeight="Bold" Foreground="#ADB5BD" Margin="0,0,0,5"/>
                                    <ItemsControl ItemsSource="{Binding SubjectRoles}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,10,5">
                                                    <TextBlock Text="{Binding RoleName}" 
                           FontSize="10" 
                           FontWeight="Bold" 
                           Foreground="#4A90E2" 
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"/>
                                                    <TextBlock Text="{Binding IdSubjectNavigation.LastName}" 
                           FontSize="13"
                           Foreground="#2D3436" 
                           VerticalAlignment="Center"/>

                                                    <TextBlock Text=";" Foreground="#ADB5BD" VerticalAlignment="Center" Margin="2,0,0,0"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                            <Setter TargetName="CardBorder" Property="BorderBrush" Value="{StaticResource PrimaryGreen}"/>
                            <Setter TargetName="CardBorder" Property="BorderThickness" Value="2"/>
                            <Setter TargetName="CardBorder" Property="Background" Value="#F9FDFB"/>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Row="2" Background="White" CornerRadius="20" Padding="12" Margin="0,15,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <StackPanel.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Height" Value="40"/>
                        <Setter Property="Width" Value="150"/>
                        <Setter Property="Margin" Value="5,0"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </StackPanel.Resources>
                <Button Content="ПОДРОБНЕЕ" Command="{Binding ShowSubjectDetailsCommand}" Background="{StaticResource SecondaryBlue}" Foreground="#2C3E50"/>
                <Button Content="ДОБАВИТЬ" Command="{Binding AddParticipantCommand}" Background="{StaticResource PrimaryGreen}" Foreground="#2D4A3E"/>
                <Button Content="ОБНОВИТЬ" Command="{Binding RefreshCommand}" Background="{StaticResource SecondaryYellow}" Foreground="#5D5B1A"/>
                <Button Content="УДАЛИТЬ" Command="{Binding RemoveParticipantCommand}" Background="{StaticResource PrimaryPink}" Foreground="#A64452"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
