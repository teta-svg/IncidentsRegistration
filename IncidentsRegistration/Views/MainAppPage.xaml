<Page x:Class="IncidentsRegistration.Views.MainAppPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      Title="Главная">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <DrawingBrush x:Key="BackgroundPatternBrush" TileMode="Tile" Viewport="0,0,100,100" ViewportUnits="Absolute" Opacity="0.1">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="{StaticResource SecondaryYellow}">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="10,10,20,20"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="{StaticResource PrimaryPink}">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="50,40,15,15"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="{StaticResource SecondaryBlue}">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="20,70,25,25"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,1,0,1"/>
            <Setter Property="Background" Value="{StaticResource SecondaryYellow}"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource PrimaryPink}"
                                BorderThickness="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource SecondaryBlue}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryPink}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource PrimaryGreen}">
        <Rectangle Fill="{StaticResource BackgroundPatternBrush}" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource PrimaryGreen}"
                    BorderBrush="{StaticResource PrimaryPink}"
                    BorderThickness="0,0,4,0">

                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,10,0,25">
                        <Border Width="65"
                                Height="65"
                                Background="{StaticResource PrimaryPink}"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,10">

                            <Image Source="/Resources/logo.png"
                                   Stretch="Uniform" 
                                   Margin="-9,-5,-9,-5"/>
                        </Border>
                        <TextBlock Text="Центр Мониторинга Безопасности" 
                                   FontSize="24" 
                                   FontWeight="Bold" 
                                   Foreground="Black"/>
                        <TextBlock Text="Безопасности" 
                                   FontSize="24" 
                                   FontWeight="Bold" 
                                   Foreground="Black"/>
                        <TextBlock Text="СИСТЕМА УПРАВЛЕНИЯ" 
                                   FontSize="9" 
                                   FontWeight="Bold" 
                                   Foreground="Black" 
                                   Opacity="0.6"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="ОСНОВНОЕ" 
                                       FontSize="11" 
                                       FontWeight="Bold" 
                                       Foreground="Black" 
                                       Margin="0,10,0,8"/>
                            <Button Content="ВСЕ ИНЦИДЕНТЫ"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Visibility="{Binding CanSeeAllIncidents, Converter={StaticResource BoolToVis}}"
                                    Command="{Binding OpenIncidentsCommand}"/>
                            <Button Content="АКТИВНЫЕ ИНЦИДЕНТЫ" 
                                    Style="{StaticResource MenuButtonStyle}" 
                                    Visibility="{Binding IsLead, Converter={StaticResource BoolToVis}}" 
                                    Command="{Binding OpenActiveIncidentsCommand}"/>
                            <Button Content="УЧАСТНИКИ" 
                                    Style="{StaticResource MenuButtonStyle}" 
                                    Visibility="{Binding IsLead, Converter={StaticResource BoolToVis}}" 
                                   Command="{Binding OpenSubjectsCommand}"/>

                            <TextBlock Text="АНАЛИТИКА" 
                                       FontSize="11" 
                                       FontWeight="Bold" 
                                       Foreground="Black" 
                                       Margin="0,20,0,8" 
                                       Visibility="{Binding CanSeeOperational, Converter={StaticResource BoolToVis}}"/>
                            <Button Content="СКАЧАТЬ ОТЧЕТ" 
                                    Style="{StaticResource MenuButtonStyle}" 
                                    Visibility="{Binding CanSeeOperational, Converter={StaticResource BoolToVis}}" 
                                    Command="{Binding ExportGeneralReportCommand}"/>

                            <TextBlock Text="АДМИНИСТРИРОВАНИЕ" 
                                       FontSize="11" 
                                       FontWeight="Bold" 
                                       Foreground="Black" 
                                       Margin="0,20,0,8" 
                                       Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"/>
                            <Button Content="ГРУППЫ РЕАГИРОВАНИЯ" 
                                    Style="{StaticResource MenuButtonStyle}" 
                                    Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}" 
                                    Command="{Binding OpenTeamsCommand}"/>
                            <Button Content="ПОЛЬЗОВАТЕЛИ" 
                                    Style="{StaticResource MenuButtonStyle}" 
                                    Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}" 
                                    Command="{Binding OpenUsersCommand}"/>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Margin="0,15,0,0">
                        <Border Background="{StaticResource SecondaryBlue}" 
                                BorderBrush="{StaticResource PrimaryPink}" 
                                BorderThickness="2" Padding="10" Margin="0,0,0,10">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="РОЛЬ ДОСТУПА" 
                                               FontSize="9" 
                                               FontWeight="Bold" 
                                               Foreground="Black"/>
                                    <TextBlock Text="{Binding Role}" 
                                               FontSize="14" 
                                               FontWeight="Bold" 
                                               Foreground="Black"/>
                                </StackPanel>
                                <Rectangle Fill="{StaticResource SecondaryYellow}" 
                                           Width="4" 
                                           HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <Border Background="{StaticResource SecondaryYellow}"
                                BorderBrush="{StaticResource PrimaryPink}"
                                BorderThickness="2"
                                Padding="10"
                                Margin="0,0,0,10"
                                Visibility="{Binding IsLead, Converter={StaticResource BoolToVis}}">

                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="ГРУППА РЕАГИРОВАНИЯ"
                                               FontSize="9"
                                               FontWeight="Bold"
                                               Foreground="Black"/>

                                    <TextBlock Text="{Binding TeamName}"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="Black"
                                               Margin="0,2,0,8"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="220"
                                               ToolTip="{Binding TeamName}"/>

                                    <TextBlock Text="РУКОВОДИТЕЛЬ ГРУППЫ"
                                               FontSize="9"
                                               FontWeight="Bold"
                                               Foreground="Black"/>

                                    <TextBlock Text="{Binding TeamLeadName}"
                                               FontWeight="Bold"
                                               Foreground="Black"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap"
                                               MaxWidth="220"
                                               ToolTip="{Binding TeamLeadName}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Button Content="ВЫХОД" 
                                Height="45" 
                                Background="{StaticResource PrimaryPink}" 
                                Foreground="Black" 
                                FontWeight="Bold" 
                                BorderThickness="2" 
                                BorderBrush="{StaticResource PrimaryPink}" 
                                Command="{Binding LogoutCommand}">
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="20">
                <Border BorderBrush="{StaticResource PrimaryPink}" 
                        BorderThickness="2" 
                        Background="{StaticResource SecondaryBlue}" 
                        Opacity="0.05"/>
                <Frame x:Name="ContentFrame"
                       NavigationUIVisibility="Hidden"
                       JournalOwnership="OwnsJournal"/>
            </Grid>
        </Grid>
    </Grid>
</Page>