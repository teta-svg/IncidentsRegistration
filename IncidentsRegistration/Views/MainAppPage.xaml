<Page x:Class="IncidentsRegistration.Views.MainAppPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://openxmlformats.org"
      Background="#F0F2F5" Title="Главная">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#636E72"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12" Margin="10,2">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E9ECEF"/>
                                <Setter Property="Foreground" Value="#2D3436"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" Margin="0" BorderBrush="#E9ECEF" BorderThickness="0,0,1,0">
            <Grid Margin="10,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="15,0,0,30">
                    <Border Background="{StaticResource PrimaryGreen}" Width="35" Height="35" CornerRadius="10">
                        <TextBlock Text="🛡️" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18"/>
                    </Border>
                    <TextBlock Text="Рапорт" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="15,0" Foreground="#2D3436"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="ОСНОВНОЕ" FontSize="10" FontWeight="Bold" Foreground="#ADB5BD" Margin="25,0,0,10"/>

                    <Button Content="Все инциденты" Style="{StaticResource MenuButtonStyle}"
                            Visibility="{Binding CanSeeAllIncidents, Converter={StaticResource BoolToVis}}"
                            Click="Incidents_Click"/>

                    <Button Content="Активные инциденты" Style="{StaticResource MenuButtonStyle}"
                            Visibility="{Binding IsLead, Converter={StaticResource BoolToVis}}"
                            Click="ActiveIncidents_Click"/>

                    <Button Content="Участники" Style="{StaticResource MenuButtonStyle}"
                            Visibility="{Binding IsLead, Converter={StaticResource BoolToVis}}"
                            Click="Subjects_Click"/>

                    <TextBlock Text="АНАЛИТИКА"  Visibility="{Binding CanSeeOperational, Converter={StaticResource BoolToVis}}" FontSize="10" FontWeight="Bold" Foreground="#ADB5BD" Margin="25,20,0,10"/>

                    <Button Content="Отчеты" Style="{StaticResource MenuButtonStyle}"
                            Visibility="{Binding CanSeeOperational, Converter={StaticResource BoolToVis}}"
                            Command="{Binding ExportGeneralReportCommand}"/>

                    <TextBlock Text="АДМИНИСТРИРОВАНИЕ" FontSize="10" FontWeight="Bold" Foreground="#ADB5BD" Margin="25,20,0,10"
                               Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"/>

                    <Button Content="Группы реагирования" Style="{StaticResource MenuButtonStyle}"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"
                            Click="Teams_Click"/>

                    <Button Content="Пользователи" Style="{StaticResource MenuButtonStyle}"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"
                            Click="Users_Click"/>
                </StackPanel>

                <!-- Замените весь Border в Grid.Row="2" на этот блок -->
                <StackPanel Grid.Row="2" Margin="10,0">
                    <!-- Инфо о роли -->
                    <Border Background="{StaticResource SecondaryBlue}" CornerRadius="15" Padding="15" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Вы вошли как:" FontSize="10" Foreground="#4A90E2" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Role}" FontSize="13" FontWeight="SemiBold" Margin="0,2,0,0" Foreground="#2D3436"/>
                        </StackPanel>
                    </Border>

                    <Button Content="Выйти из системы" 
                            Click="Logout_Click"
                            Style="{StaticResource MenuButtonStyle}"
                            Foreground="#A64452" 
                            Margin="0,0,0,10">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="12"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>

            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Border Background="#F8F9FA" Margin="0" CornerRadius="0">
                <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
            </Border>
        </Grid>
    </Grid>
</Page>
