<Page x:Class="IncidentsRegistration.Views.IncidentDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:IncidentsRegistration.Views"
      Title="Детали инцидента">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!-- Заголовок -->
                <RowDefinition Height="Auto" />
                <!-- Инфо об инциденте и Группе -->
                <RowDefinition Height="Auto" />
                <!-- Локация -->
                <RowDefinition Height="Auto" />
                <!-- Субъекты (Участники) -->
                <RowDefinition Height="Auto" />
                <!-- Решение -->
                <RowDefinition Height="Auto" />
                <!-- Кнопка назад -->
            </Grid.RowDefinitions>

            <!-- 0. Заголовок -->
            <TextBlock Text="{Binding IncidentTitle}" FontSize="26" FontWeight="Bold" Grid.Row="0" Margin="0,0,0,20"/>

            <!-- 1. Основная информация и Группа -->
            <UniformGrid Columns="2" Grid.Row="1">
                <Border BorderBrush="Black" BorderThickness="2" Margin="0,0,10,10" Padding="15">
                    <StackPanel>
                        <TextBlock Text="ИНФОРМАЦИЯ ОБ ИНЦИДЕНТЕ" FontWeight="Bold" Margin="0,0,0,10" Foreground="Gray"/>
                        <TextBlock Text="{Binding SelectedIncident.TypeOfIncident, StringFormat='Тип: {0}'}" FontSize="16" Margin="0,5"/>
                        <TextBlock Text="{Binding SelectedIncident.RegistrationDate, StringFormat='Дата: {0:dd.MM.yyyy}'}" Margin="0,2"/>
                        <TextBlock Text="{Binding SelectedIncident.RegistrationTime, StringFormat='Время: {0:HH:mm}'}" Margin="0,2"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="Black" BorderThickness="2" Margin="10,0,0,10" Padding="15">
                    <StackPanel>
                        <TextBlock Text="ГРУППА РЕАГИРОВАНИЯ" FontWeight="Bold" Margin="0,0,0,10" Foreground="Gray"/>
                        <TextBlock Text="{Binding SelectedIncident.IdResponseTeamNavigation.NameTeam}" FontSize="16" FontWeight="Bold"/>
                        <TextBlock Text="{Binding DirectorFullName, StringFormat='Руководитель: {0}'}"/>
                        <TextBlock Text="{Binding SelectedIncident.IdResponseTeamNavigation.NumberOfPeople, StringFormat='Состав: {0} чел.'}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- 2. Локация -->
            <Border Grid.Row="2" BorderBrush="Black" BorderThickness="2" Margin="0,10" Padding="15">
                <StackPanel>
                    <TextBlock Text="МЕСТО ПРОИСШЕСТВИЯ" FontWeight="Bold" Margin="0,0,0,10" Foreground="Gray"/>
                    <ItemsControl ItemsSource="{Binding SelectedIncident.IncidentLocations}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontSize="14">
                                    <Run Text="{Binding IdLocationNavigation.Region, Mode=OneWay}"/>, 
                                    <Run Text="{Binding IdLocationNavigation.Settlement, Mode=OneWay}"/>, 
                                    <Run Text="{Binding IdLocationNavigation.Street, Mode=OneWay}"/>, 
                                    д. <Run Text="{Binding IdLocationNavigation.House, Mode=OneWay}"/>, 
                                    кв. <Run Text="{Binding IdLocationNavigation.Room, Mode=OneWay}"/>
                                    <LineBreak/>
                                    <Run Text="Координаты: " Foreground="Gray"/> 
                                    [<Run Text="{Binding IdLocationNavigation.CoordinateX}"/> ; <Run Text="{Binding IdLocationNavigation.CoordinateY}"/>]
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- 3. Субъекты (Участники) -->
            <Border Grid.Row="3" BorderBrush="Black" BorderThickness="2" Margin="0,10" Padding="15">
                <StackPanel>
                    <TextBlock Text="УЧАСТНИКИ (СУБЪЕКТЫ)" FontWeight="Bold" Margin="0,0,0,10" Foreground="Gray"/>
                    <DataGrid ItemsSource="{Binding SelectedIncident.SubjectRoles}" 
                              AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                              BorderThickness="1" BorderBrush="Black" GridLinesVisibility="All">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ФИО" Width="*">
                                <DataGridTextColumn.Binding>
                                    <MultiBinding StringFormat="{}{0} {1} {2}">
                                        <Binding Path="IdSubjectNavigation.LastName"/>
                                        <Binding Path="IdSubjectNavigation.FirstName"/>
                                        <Binding Path="IdSubjectNavigation.Patronymic"/>
                                    </MultiBinding>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Роль" Binding="{Binding RoleName}" Width="150"/>
                            <DataGridTextColumn Header="Судимости" Binding="{Binding IdSubjectNavigation.NumberOfConvictions}" Width="80"/>
                            <DataGridTextColumn Header="Адрес" Width="200">
                                <DataGridTextColumn.Binding>
                                    <MultiBinding StringFormat="{}{0}, {1}, {2}">
                                        <Binding Path="IdSubjectNavigation.Settlement"/>
                                        <Binding Path="IdSubjectNavigation.Street"/>
                                        <Binding Path="IdSubjectNavigation.House"/>
                                    </MultiBinding>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <Border Grid.Row="4" BorderBrush="Black" BorderThickness="2" Margin="0,10" Padding="15" Background="#F9F9F9">
                <StackPanel>
                    <TextBlock Text="ИТОГОВОЕ РЕШЕНИЕ" FontWeight="Bold" Margin="0,0,0,10" Foreground="DarkRed"/>

                    <StackPanel>
                        <TextBlock Text="{Binding SelectedIncident.Decision.DecisionType, StringFormat='Статус: {0}'}" FontSize="18" FontWeight="Bold"/>

                        <StackPanel Visibility="{Binding CaseVisibility}">
                            <TextBlock Text="{Binding SelectedIncident.Decision.CriminalCase.СaseNumber, StringFormat='Уголовное дело №: {0}'}"/>
                            <TextBlock Text="{Binding SelectedIncident.Decision.CriminalCase.Qualification, StringFormat='Квалификация: {0}'}"/>
                        </StackPanel>

                        <!-- Если передача -->
                        <StackPanel Visibility="{Binding TransferVisibility}">
                            <TextBlock Text="{Binding SelectedIncident.Decision.TerritorialTransfer.Division, StringFormat='Передано в подразделение: {0}'}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 5. Кнопка назад -->
            <Button Content="ВЕРНУТЬСЯ К СПИСКУ" 
                    Grid.Row="5" 
                    Height="40" 
                    Width="200" 
                    HorizontalAlignment="Left" 
                    Margin="0,20,0,0" 
                    Click="Back_Click"/>
        </Grid>
    </ScrollViewer>
</Page>
