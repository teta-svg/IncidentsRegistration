<Page x:Class="IncidentsRegistration.Views.IncidentDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      Background="#F0F2F5" Title="Детали инцидента">

    <Page.Resources>
        <Style TargetType="TextBlock" x:Key="CardHeader">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#8B959E"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,25">
                <TextBlock Text="ПРОСМОТР ДЕТАЛЕЙ" FontSize="11" FontWeight="Bold" Foreground="#8B959E"/>
                <TextBlock Text="{Binding IncidentTitle}" FontSize="32" FontWeight="SemiBold" Foreground="#2D3436"/>
            </StackPanel>

            <UniformGrid Columns="2" Grid.Row="1">
                <Border Background="White" CornerRadius="20" Margin="0,0,10,20" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.06"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="ИНФОРМАЦИЯ ОБ ИНЦИДЕНТЕ" Style="{StaticResource CardHeader}"/>
                        <TextBlock Text="{Binding SelectedIncident.TypeOfIncident}" FontSize="20" FontWeight="Bold" Foreground="#2D3436"/>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Border Background="{StaticResource SecondaryBlue}" CornerRadius="8" Padding="10,5" Margin="0,0,10,0">
                                <TextBlock Text="{Binding SelectedIncident.RegistrationTime, StringFormat=\{0:HH:mm\}}" FontWeight="Bold" Foreground="#4A90E2"/>
                            </Border>
                            <TextBlock Text="{Binding SelectedIncident.RegistrationDate, StringFormat=\{0:dd MMMM yyyy\}}" VerticalAlignment="Center" Foreground="#636E72"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="20" Margin="10,0,0,20" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.06"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="ГРУППА РЕАГИРОВАНИЯ" Style="{StaticResource CardHeader}"/>
                        <TextBlock Text="{Binding SelectedIncident.IdResponseTeamNavigation.NameTeam}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryGreen}"/>
                        <TextBlock Text="{Binding DirectorFullName, StringFormat='Руководитель: {0}'}" Margin="0,8,0,0" Foreground="#636E72"/>
                        <TextBlock Text="{Binding SelectedIncident.IdResponseTeamNavigation.NumberOfPeople, StringFormat='Состав: {0} человек'}" Foreground="#8B959E" FontSize="12"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Grid.Row="2" Background="White" CornerRadius="20" Margin="0,0,0,20" Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.06"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="МЕСТО ПРОИСШЕСТВИЯ" Style="{StaticResource CardHeader}"/>
                    <ItemsControl ItemsSource="{Binding SelectedIncident.IncidentLocations}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="#F1F3F5" Width="40" Height="40" CornerRadius="20" Margin="0,0,15,0">
                                        <TextBlock Text="📍" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock FontSize="16" Foreground="#2D3436">
                                            <Run Text="{Binding IdLocationNavigation.Region}"/>, 
                                            <Run Text="{Binding IdLocationNavigation.Settlement}"/>, 
                                            <Run Text="{Binding IdLocationNavigation.Street}"/>, 
                                            д. <Run Text="{Binding IdLocationNavigation.House}"/>, 
                                            кв. <Run Text="{Binding IdLocationNavigation.Room}"/>
                                        </TextBlock>
                                        <TextBlock Foreground="#8B959E" FontSize="12" Margin="0,4,0,0">
                                            <Run Text="Координаты GPS: "/> 
                                            <Run Text="{Binding IdLocationNavigation.CoordinateX}" FontWeight="Medium"/> ; 
                                            <Run Text="{Binding IdLocationNavigation.CoordinateY}" FontWeight="Medium"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Background="White" CornerRadius="20" Margin="0,0,0,20" Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.06"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="УЧАСТНИКИ ПРОИСШЕСТВИЯ" Style="{StaticResource CardHeader}"/>
                    <DataGrid ItemsSource="{Binding SelectedIncident.SubjectRoles}" 
                              AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                              Background="Transparent" BorderThickness="0" GridLinesVisibility="None"
                              RowHeight="40" HeadersVisibility="Column">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#8B959E"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="10,0,0,10"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#F1F3F5"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ФИО" Width="*">
                                <DataGridTextColumn.Binding>
                                    <MultiBinding StringFormat="{}{0} {1} {2}">
                                        <Binding Path="IdSubjectNavigation.LastName"/>
                                        <Binding Path="IdSubjectNavigation.FirstName"/>
                                        <Binding Path="IdSubjectNavigation.Patronymic"/>
                                    </MultiBinding>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Роль" Binding="{Binding RoleName}" Width="120"/>
                            <DataGridTextColumn Header="Судимости" Binding="{Binding IdSubjectNavigation.NumberOfConvictions}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <Border Grid.Row="4" Background="White" CornerRadius="20" Padding="25" BorderThickness="2" BorderBrush="{StaticResource PrimaryPink}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.1"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="{StaticResource PrimaryPink}" Width="60" Height="60" CornerRadius="30" Margin="0,0,20,0">
                        <TextBlock Text="⚖️" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="ИТОГОВОЕ РЕШЕНИЕ" FontWeight="Bold" FontSize="11" Foreground="#A64452" Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding SelectedIncident.Decision.DecisionType}" FontSize="22" FontWeight="Bold" Foreground="#2D3436"/>

                        <StackPanel Visibility="{Binding CaseVisibility}" Margin="0,10,0,0">
                            <TextBlock Foreground="#636E72">
                                <Run Text="Номер дела: " FontWeight="SemiBold"/>
                                <Run Text="{Binding SelectedIncident.Decision.CriminalCase.СaseNumber}" Foreground="#2D3436"/>
                            </TextBlock>
                            <TextBlock Text="{Binding SelectedIncident.Decision.CriminalCase.Qualification, StringFormat='Квалификация: {0}'}" Foreground="#636E72"/>
                        </StackPanel>

                        <StackPanel Visibility="{Binding TransferVisibility}" Margin="0,10,0,0">
                            <TextBlock Text="{Binding SelectedIncident.Decision.TerritorialTransfer.Division, StringFormat='Передано в: {0}'}" Foreground="#636E72" FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Button Content="ВЕРНУТЬСЯ К СПИСКУ" 
                    Grid.Row="5" 
                    Height="45" 
                    Width="220" 
                    HorizontalAlignment="Left" 
                    Margin="0,30,0,0" 
                    Click="Back_Click"
                    Background="Transparent"
                    Foreground="#8B959E"
                    FontWeight="SemiBold"
                    BorderThickness="0"/>
        </Grid>
    </ScrollViewer>
</Page>
