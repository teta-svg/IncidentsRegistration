<Page x:Class="IncidentsRegistration.Views.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      Title="Регистрация"
      MinWidth="1000"
      MinHeight="700">

    <Grid>

        <Canvas IsHitTestVisible="False">

            <Rectangle Width="350"
                       Height="350"
                       Fill="{StaticResource PrimaryGreen}"
                       Opacity="0.35"
                       Canvas.Left="-120"
                       Canvas.Top="-120"/>

            <Rectangle Width="280"
                       Height="500"
                       Fill="{StaticResource PrimaryPink}"
                       Opacity="0.3"
                       Canvas.Left="780"
                       Canvas.Top="250"/>

            <Rectangle Width="180"
                       Height="180"
                       Fill="{StaticResource SecondaryYellow}"
                       Opacity="0.6"
                       Canvas.Left="120"
                       Canvas.Top="500"/>
        </Canvas>

        <Border Width="500"
                Padding="50"
                Background="{StaticResource PrimaryGreen}"
                BorderBrush="{StaticResource PrimaryPink}"
                BorderThickness="4"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>

                <Border Width="70"
                        Height="70"
                        Background="{StaticResource PrimaryPink}"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,25">

                    <Image Source="/Resources/logo.png"
                           Width="120"
                           Height="120"
                           Stretch="Uniform" 
                           Margin="-25,-26,-25,-24"/>
                    
                </Border>

                <TextBlock Text="Центр Мониторинга Безопасности"
                           FontSize="18"
                           Foreground="Black"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <TextBlock Text="Регистрация"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="Black"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <TextBlock Text="Логин"
                           FontSize="14"
                           Margin="0,0,0,8"
                           Foreground="Black"/>

                <TextBox Text="{Binding Login}"
                         VerticalContentAlignment="Center"
                         Height="55"
                         FontSize="18"
                         Background="{StaticResource SecondaryYellow}"
                         Foreground="Black"
                         BorderBrush="{StaticResource PrimaryPink}"
                         BorderThickness="3"
                         Padding="15,0"
                         Margin="0,0,0,25"/>

                <TextBlock Text="Пароль"
                           FontSize="14"
                           Margin="0,0,0,8"
                           Foreground="Black"/>
                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <PasswordBox x:Name="PasswordBox"
                 Grid.Row="0"
                 VerticalContentAlignment="Center"
                 Height="55"
                 FontSize="18"
                 Background="{StaticResource SecondaryYellow}"
                 Foreground="Black"
                 BorderBrush="{StaticResource PrimaryPink}"
                 BorderThickness="3"
                 Padding="15,0"
                 Margin="0,0,0,12"/>

                    <TextBox x:Name="PasswordTextBox"
             Grid.Row="0"
             VerticalContentAlignment="Center"
             Visibility="Collapsed"
             Height="55"
             FontSize="18"
             Background="{StaticResource SecondaryYellow}"
             Foreground="Black"
             BorderBrush="{StaticResource PrimaryPink}"
             BorderThickness="3"
             Padding="15,0"
             Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="1"
               Text="Подтвердите пароль"
               FontSize="14"
               Margin="0,5,0,8"
               Foreground="Black"/>

                    <PasswordBox x:Name="ConfirmPasswordBox"
                 Grid.Row="2"
                 VerticalContentAlignment="Center"
                 Height="55"
                 FontSize="18"
                 Background="{StaticResource SecondaryYellow}"
                 Foreground="Black"
                 BorderBrush="{StaticResource PrimaryPink}"
                 BorderThickness="3"
                 Padding="15,0"
                 Margin="0,0,0,12"/>

                    <TextBox x:Name="ConfirmPasswordTextBox"
             Grid.Row="2"
             VerticalContentAlignment="Center"
             Visibility="Collapsed"
             Height="55"
             FontSize="18"
             Background="{StaticResource SecondaryYellow}"
             Foreground="Black"
             BorderBrush="{StaticResource PrimaryPink}"
             BorderThickness="3"
             Padding="15,0"
             Margin="0,0,0,12"/>

                    <Border Grid.Row="3"
            Background="{StaticResource SecondaryYellow}"
            BorderBrush="{StaticResource PrimaryPink}"
            BorderThickness="2"
            Padding="12,8"
            HorizontalAlignment="Left"
            CornerRadius="6">

                        <CheckBox Content="Показать пароль"
    FontSize="14"
    FontWeight="SemiBold"
    Foreground="Black"
    Background="Transparent"
    BorderThickness="0"
    Cursor="Hand"
    Checked="ShowPassword_Checked"
    Unchecked="ShowPassword_Unchecked"
                    HorizontalAlignment="Left" 
VerticalAlignment="Center" Width="148"/>
                    </Border>

                </Grid>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource PrimaryPink}"
                           Background="{StaticResource SecondaryYellow}"
                           FontSize="14"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,20"/>

                <UniformGrid Columns="2"
                             Rows="1">

                    <Button Content="Создать"
                            Height="60"
                            Margin="0,0,8,0"
                            FontSize="18"
                            FontWeight="Bold"
                            Background="{StaticResource PrimaryPink}"
                            Foreground="Black"
                            BorderThickness="0"
                            Click="Register_Click"/>

                    <Button Content="Назад"
                            Height="60"
                            Margin="8,0,0,0"
                            FontSize="18"
                            FontWeight="Bold"
                            Background="{StaticResource SecondaryYellow}"
                            Foreground="Black"
                            BorderThickness="0"
                            Command="{Binding BackToLoginCommand}"/>
                </UniformGrid>

            </StackPanel>
        </Border>
    </Grid>
</Page>