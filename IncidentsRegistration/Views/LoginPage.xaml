<Page x:Class="IncidentsRegistration.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Вход">

    <Border Background="{StaticResource SecondaryYellow}" 
         CornerRadius="15" 
         Padding="30" 
         Width="320" 
         VerticalAlignment="Center">

        <StackPanel>

            <TextBlock Text="ВХОД"
                           FontSize="20"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

            <TextBlock Text="Логин" Margin="5,0,0,0"/>
            <TextBox Text="{Binding Login}" Margin="0,5,0,10"/>

            <TextBlock Text="Пароль" Margin="5,0,0,0"/>
            <PasswordBox x:Name="PasswordBox" Margin="0,5,0,15"/>

            <Button Content="ВОЙТИ"
                    Height="40"
                    Background="{StaticResource PrimaryGreen}"
                    Foreground="White"
                    FontWeight="Bold"
                    Margin="0,5,0,15"
                    Click="Login_Click"/>
            <Button Content="ЗАРЕГЕСТРИРОВАТЬСЯ"
                    Height="40"
                    Background="{StaticResource PrimaryGreen}"
                    Foreground="White"
                    FontWeight="Bold"
                    Click="GoToRegister_Click"/>
        </StackPanel>
    </Border>
</Page>