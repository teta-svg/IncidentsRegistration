<Page x:Class="IncidentsRegistration.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F0F2F5" Title="Вход">

    <Page.Resources>
        <Style x:Key="LoginField" TargetType="Control">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Control">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="1" CornerRadius="12">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="5,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Border Background="White" 
                CornerRadius="25" 
                Padding="40" 
                Width="380" 
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.1"/>
            </Border.Effect>

            <StackPanel>
                <Border Background="{StaticResource SecondaryYellow}" 
                        Width="60" Height="60" CornerRadius="30" Margin="0,0,0,20">
                    <TextBlock Text="👤" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="Авторизация"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="#2D3436"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,5"/>

                <TextBlock Text="Введите ваши данные для доступа"
                           FontSize="12"
                           Foreground="#8B959E"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <TextBlock Text="Логин" FontSize="11" FontWeight="Bold" Foreground="#8B959E" Margin="5,0,0,5"/>
                <TextBox Text="{Binding Login}" Style="{StaticResource LoginField}" Margin="0,0,0,20"/>

                <TextBlock Text="Пароль" FontSize="11" FontWeight="Bold" Foreground="#8B959E" Margin="5,0,0,5"/>
                <PasswordBox x:Name="PasswordBox" Style="{StaticResource LoginField}" Margin="0,0,0,30"/>
                <Button Content="ВОЙТИ"
                        Height="50"
                        Background="{StaticResource PrimaryGreen}"
                        Foreground="#2D4A3E"
                        FontWeight="Bold"
                        Margin="0,0,0,12"
                        Click="Login_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="15"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Создать аккаунт"
                        Background="Transparent"
                        Foreground="#8B959E"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="GoToRegister_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>