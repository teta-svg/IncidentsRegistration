<Page x:Class="IncidentsRegistration.Views.IncidentDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      Title="Детали инцидента">

    <Page.Resources>

        <Style x:Key="SectionHeaderBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PrimaryPink}"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style x:Key="SectionHeaderText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="45"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,0,0,10"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryPink}"/>
        </Style>
    </Page.Resources>

    <Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="35">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,30">
                    <TextBlock Text="ДЕТАЛИ ИНЦИДЕНТА" 
                               FontSize="11" 
                               FontWeight="Bold" 
                               Foreground="Black" 
                               Opacity="0.6"/>
                    <StackPanel Orientation="Horizontal" 
                                Margin="0,5,0,0">
                        <Border Background="{StaticResource SecondaryYellow}" 
                                Width="8" 
                                Height="40" 
                                Margin="0,0,15,0"/>
                        <TextBlock Text="{Binding IncidentTitle}" 
                                   FontSize="38" 
                                   FontWeight="ExtraBold" 
                                   Foreground="Black"/>
                    </StackPanel>
                </StackPanel>

                <UniformGrid Columns="2" Grid.Row="1">
                    <Border Background="{StaticResource SecondaryBlue}" 
                            BorderBrush="{StaticResource PrimaryPink}" 
                            BorderThickness="2" 
                            Margin="0,0,10,20" 
                            Padding="25">
                        <StackPanel>
                            <Border Style="{StaticResource SectionHeaderBorder}">
                                <TextBlock Text="ИНФОРМАЦИЯ" 
                                           Style="{StaticResource SectionHeaderText}"/>
                            </Border>
                            <TextBlock Text="{Binding SelectedIncident.TypeOfIncident}" 
                                       FontSize="22" 
                                       FontWeight="Bold" 
                                       Foreground="Black"/>
                            <StackPanel Orientation="Horizontal" 
                                        Margin="0,15,0,0">
                                <Border Background="{StaticResource SecondaryYellow}" 
                                        Padding="12,6" 
                                        Margin="0,0,12,0">
                                    <TextBlock Text="{Binding SelectedIncident.RegistrationTime, StringFormat=\{0:HH:mm\}}" 
                                               FontWeight="Bold" 
                                               Foreground="Black"/>
                                </Border>
                                <TextBlock Text="{Binding SelectedIncident.RegistrationDate, StringFormat=\{0:dd MMMM yyyy\}}" 
                                           VerticalAlignment="Center" 
                                           Foreground="Black" 
                                           FontSize="15"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource SecondaryBlue}" 
                            BorderBrush="{StaticResource PrimaryPink}" 
                            BorderThickness="2" 
                            Margin="10,0,0,20" 
                            Padding="25">
                        <StackPanel>
                            <Border Style="{StaticResource SectionHeaderBorder}" 
                                    Background="{StaticResource SecondaryYellow}">
                                <TextBlock Text="ГРУППА РЕАГИРОВАНИЯ" 
                                           Style="{StaticResource SectionHeaderText}"/>
                            </Border>
                            <TextBlock Text="{Binding SelectedIncident.IdResponseTeamNavigation.NameTeam}" 
                                       FontSize="22" 
                                       FontWeight="Bold" 
                                       Foreground="Black"/>
                            <TextBlock Text="{Binding DirectorFullName, StringFormat='Ответственный: {0}'}" 
                                       Margin="0,10,0,0" 
                                       Foreground="Black" 
                                       FontSize="14"/>
                            <TextBlock Text="{Binding SelectedIncident.IdResponseTeamNavigation.NumberOfPeople, StringFormat='Состав группы: {0} чел.'}" 
                                       Foreground="Black" 
                                       Opacity="0.7" 
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Border Grid.Row="2" Background="{StaticResource SecondaryBlue}" 
                        BorderBrush="{StaticResource PrimaryPink}" 
                        BorderThickness="2" 
                        Margin="0,0,0,20" 
                        Padding="25">
                    <StackPanel>
                        <Border Style="{StaticResource SectionHeaderBorder}" 
                                Background="{StaticResource PrimaryGreen}">
                            <TextBlock Text="ЛОКАЦИЯ" 
                                       Style="{StaticResource SectionHeaderText}"/>
                        </Border>
                        <ItemsControl ItemsSource="{Binding SelectedIncident.IncidentLocations}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Background="{StaticResource SecondaryYellow}" 
                                                Width="45" 
                                                Height="45" 
                                                Margin="0,0,20,0">
                                            <TextBlock Text="📍" 
                                                       FontSize="20" 
                                                       HorizontalAlignment="Center" 
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" 
                                                    VerticalAlignment="Center">
                                            <TextBlock FontSize="17" 
                                                       Foreground="Black" 
                                                       FontWeight="Medium">
                                                <Run Text="{Binding IdLocationNavigation.Region}"/>, 
                                                <Run Text="{Binding IdLocationNavigation.Settlement}"/>, 
                                                <Run Text="{Binding IdLocationNavigation.Street}"/>, д. 
                                                <Run Text="{Binding IdLocationNavigation.House}"/>
                                            </TextBlock>
                                            <TextBlock Foreground="Black" Opacity="0.6" FontSize="12" Margin="0,3,0,0">
                                                <Run Text="Координаты: "/> 
                                                <Run Text="{Binding IdLocationNavigation.CoordinateX}"/>, 
                                                <Run Text="{Binding IdLocationNavigation.CoordinateY}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Row="3" Background="{StaticResource SecondaryBlue}" 
                        BorderBrush="{StaticResource PrimaryPink}" 
                        BorderThickness="2" 
                        Margin="0,0,0,20" 
                        Padding="25">
                    <StackPanel>
                        <Border Style="{StaticResource SectionHeaderBorder}">
                            <TextBlock Text="УЧАСТНИКИ" 
                                       Style="{StaticResource SectionHeaderText}"/>
                        </Border>
                        <DataGrid ItemsSource="{Binding SelectedIncident.SubjectRoles}" 
                                  AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ФИО ПОЛНОСТЬЮ" Width="*">
                                    <DataGridTextColumn.Binding>
                                        <MultiBinding StringFormat="{}{0} {1} {2}">
                                            <Binding Path="IdSubjectNavigation.LastName"/>
                                            <Binding Path="IdSubjectNavigation.FirstName"/>
                                            <Binding Path="IdSubjectNavigation.Patronymic"/>
                                        </MultiBinding>
                                    </DataGridTextColumn.Binding>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="РОЛЬ" Binding="{Binding RoleName}" Width="150"/>
                                <DataGridTextColumn Header="СУДИМОСТИ" 
                                                    Binding="{Binding IdSubjectNavigation.NumberOfConvictions}" 
                                                    Width="110"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="4" Background="{StaticResource PrimaryPink}" 
                        BorderBrush="{StaticResource SecondaryYellow}" 
                        BorderThickness="2" 
                        Padding="30">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="{StaticResource SecondaryYellow}" 
                                Width="70" Height="70" 
                                Margin="0,0,25,0">
                            <TextBlock Text="⚖️" 
                                       FontSize="36" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="ПРИНЯТОЕ РЕШЕНИЕ" 
                                       FontWeight="Bold" 
                                       FontSize="11" 
                                       Opacity="0.7"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SelectedIncident.Decision.DecisionType}" 
                                       FontSize="26" 
                                       FontWeight="ExtraBold" 
                                       Foreground="Black"/>

                            <StackPanel Visibility="{Binding CaseVisibility}" Margin="0,8,0,0">
                                <TextBlock Foreground="Black" FontSize="15">
                                    <Run Text="Уголовное дело №" FontWeight="Bold"/> 
                                    <Run Text="{Binding SelectedIncident.Decision.CriminalCase.СaseNumber}"/>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Visibility="{Binding TransferVisibility}" 
                                        Margin="0,8,0,0">
                                <TextBlock Text="{Binding SelectedIncident.Decision.TerritorialTransfer.Division, StringFormat='Направлено в: {0}'}" 
                                           Foreground="Black" 
                                           FontWeight="Bold" 
                                           FontSize="15"/>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="2" 
                                Content="НАЗАД" 
                                Height="50" 
                                Width="150" 
                                Command="{Binding BackCommand}"
                                Background="{StaticResource SecondaryBlue}" 
                                Foreground="Black" 
                                FontWeight="Bold" 
                                BorderThickness="2" 
                                BorderBrush="{StaticResource PrimaryPink}" 
                                Cursor="Hand"/>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>