<Page x:Class="IncidentsRegistration.Views.AddDecisionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Вынесение решения">

    <Page.Resources>
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Margin" Value="0,12,0,6"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,10"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryPink}"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryPink}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryPink}"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
    </Page.Resources>

    <Grid>

        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,25">
                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <Border Background="{StaticResource SecondaryYellow}" Width="8" Height="30" Margin="0,0,15,0"/>
                    <TextBlock Text="Вынесение решения" FontSize="28" FontWeight="Bold" Foreground="Black"/>
                </StackPanel>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Background="{StaticResource SecondaryBlue}" 
                            BorderBrush="{StaticResource PrimaryPink}" 
                            BorderThickness="2" Padding="25" Margin="0,0,0,20">
                        <StackPanel>
                            <Border Background="{StaticResource SecondaryYellow}" 
                                    Padding="10,4" HorizontalAlignment="Left" 
                                    Margin="0,0,0,15">
                                <TextBlock Text="ОСНОВНЫЕ ПАРАМЕТРЫ" 
                                           Foreground="Black" FontWeight="Bold" FontSize="10"/>
                            </Border>

                            <TextBlock Text="Тип выносимого решения" 
                                       Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding DecisionTypes}" 
                                      SelectedItem="{Binding SelectedType}"/>

                            <TextBlock Text="Правовое основание" 
                                       Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding NewDecision.LegalBasis}"/>

                            <TextBlock Text="Дата принятия решения" 
                                       Style="{StaticResource LabelStyle}"/>
                            <DatePicker SelectedDate="{Binding UI_DecisionDate}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource PrimaryPink}" 
                            BorderBrush="{StaticResource PrimaryPink}"
                            BorderThickness="2" Padding="25" Margin="0,0,0,20" 
                            Visibility="{Binding CriminalCaseVisibility}">
                        <StackPanel>
                            <TextBlock Text="ДАННЫЕ УГОЛОВНОГО ДЕЛА" 
                                       FontWeight="Bold" FontSize="16" 
                                       Foreground="Black" Margin="0,0,0,15"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Дата возбуждения" Style="{StaticResource LabelStyle}"/>
                                    <DatePicker SelectedDate="{Binding UI_CriminalCaseDate}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Квалификация (Статья)" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Text="{Binding NewCriminalCase.Qualification}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource SecondaryYellow}" 
                            BorderBrush="{StaticResource PrimaryPink}" 
                            BorderThickness="2" 
                            Padding="25" Margin="0,0,0,20" 
                            Visibility="{Binding TransferVisibility}">
                        <StackPanel>
                            <TextBlock Text="ТЕРРИТОРИАЛЬНАЯ ПЕРЕДАЧА" 
                                       FontWeight="Bold" 
                                       FontSize="16" 
                                       Foreground="Black" 
                                       Margin="0,0,0,15"/>
                            <TextBlock Text="Подразделение" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding NewTransfer.Division}" Margin="0,0,0,10"/>
                            <TextBlock Text="Дата передачи материалов" Style="{StaticResource LabelStyle}"/>
                            <DatePicker SelectedDate="{Binding UI_TransferDate}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource PrimaryPink}"
                           Background="{StaticResource SecondaryYellow}"
                           FontSize="14"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,20"/>

            <Border Grid.Row="2" Background="{StaticResource PrimaryGreen}" 
                    BorderBrush="{StaticResource PrimaryPink}" 
                    BorderThickness="2" Padding="12" Margin="0,15,0,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="ОТМЕНА"
                                Click="Back_Click"
                                Background="{StaticResource SecondaryBlue}" 
                                Foreground="Black" 
                                Width="140" Height="45" 
                                Margin="5,0" 
                                BorderThickness="2" 
                                BorderBrush="{StaticResource PrimaryPink}" 
                                FontWeight="Bold"/>
                        <Button Content="СОХРАНИТЬ" 
                                Command="{Binding SaveCommand}" 
                                Background="{StaticResource SecondaryYellow}" 
                                Foreground="Black" Width="180" 
                                Height="45" Margin="5,0" 
                                BorderThickness="2" 
                                BorderBrush="{StaticResource PrimaryPink}" 
                                FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>