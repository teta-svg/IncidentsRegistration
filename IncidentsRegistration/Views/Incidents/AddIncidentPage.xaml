<Page x:Class="IncidentsRegistration.Views.AddIncidentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Регистрация инцидента">

    <Page.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,10"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryPink}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Margin" Value="0,12,0,6"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryPink}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="45"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryPink}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
    </Page.Resources>

    <Grid>

        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,25">
                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <Border Background="{StaticResource SecondaryYellow}" Width="8" Height="30" Margin="0,0,15,0"/>
                    <TextBlock Text="Новый инцидент" FontSize="28" FontWeight="Bold" Foreground="Black"/>
                </StackPanel>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <UniformGrid Columns="2">
                        <Border Background="{StaticResource SecondaryBlue}" 
                                BorderBrush="{StaticResource PrimaryPink}" 
                                BorderThickness="2" Margin="0,0,10,20" Padding="20">
                            <StackPanel>
                                <Border Background="{StaticResource SecondaryYellow}" 
                                        Padding="10,4" HorizontalAlignment="Left" 
                                        Margin="0,0,0,15">
                                    <TextBlock Text="ВЫБОР СВОБОДНОЙ ГРУППЫ" 
                                               Foreground="Black" 
                                               FontWeight="Bold" FontSize="10"/>
                                </Border>
                                <ComboBox ItemsSource="{Binding FreeTeams}" 
                                          SelectedItem="{Binding SelectedTeam}" 
                                          DisplayMemberPath="NameTeam"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource SecondaryBlue}" 
                                BorderBrush="{StaticResource PrimaryPink}" 
                                BorderThickness="2" 
                                Margin="10,0,0,20"
                                Padding="20">
                            <StackPanel>
                                <Border Background="{StaticResource PrimaryGreen}" 
                                        Padding="10,4" 
                                        HorizontalAlignment="Left" 
                                        Margin="0,0,0,15">
                                    <TextBlock Text="ВРЕМЯ РЕГИСТРАЦИИ"
                                               Foreground="Black" 
                                               FontWeight="Bold" 
                                               FontSize="10"/>
                                </Border>
                                <UniformGrid Columns="2">
                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="Дата" 
                                                   Style="{StaticResource LabelStyle}"/>
                                        <DatePicker SelectedDate="{Binding DisplayDate}"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Время" 
                                                   Style="{StaticResource LabelStyle}"/>
                                        <TextBox Text="{Binding DisplayTime, StringFormat=\{0:HH:mm\}}"/>
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Border Background="{StaticResource  SecondaryBlue}" 
                            BorderBrush="{StaticResource PrimaryPink}" 
                            BorderThickness="2" Padding="25" Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="ДАННЫЕ ПРОИСШЕСТВИЯ" 
                                           FontWeight="Bold" FontSize="16" 
                                           Foreground="Black" Margin="0,0,0,15"/>
                                <TextBlock Text="Тип инцидента" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding NewIncident.TypeOfIncident}"/>
                                <TextBlock Text="Регион / Область" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding NewLocation.Region}"/>
                                <TextBlock Text="Город / Населенный пункт" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding NewLocation.Settlement}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Улица" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding NewLocation.Street}"/>
                                <UniformGrid Columns="2">
                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="Дом" Style="{StaticResource LabelStyle}"/>
                                        <TextBox Text="{Binding NewLocation.House}"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Кв/Оф" Style="{StaticResource LabelStyle}"/>
                                        <TextBox Text="{Binding NewLocation.Room}"/>
                                    </StackPanel>
                                </UniformGrid>
                                <UniformGrid Columns="2">
                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="Координата X" Style="{StaticResource LabelStyle}"/>
                                        <TextBox Text="{Binding NewLocation.CoordinateX}"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Координата Y" Style="{StaticResource LabelStyle}"/>
                                        <TextBox Text="{Binding NewLocation.CoordinateY}"/>
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource PrimaryPink}"
                           Background="{StaticResource SecondaryYellow}"
                           FontSize="14"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,20"/>

            <Border Grid.Row="2" Background="{StaticResource PrimaryGreen}" 
                    BorderBrush="{StaticResource PrimaryPink}" 
                    BorderThickness="2" Padding="12" Margin="0,15,0,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="ОТМЕНИТЬ" Width="140" Height="45" Margin="5,0" 
                                Background="{StaticResource SecondaryBlue}" 
                                Foreground="Black" BorderThickness="2" 
                                BorderBrush="{StaticResource PrimaryPink}" 
                                FontWeight="Bold"
                                Command="{Binding BackCommand}"/>
                        <Button Content="СОХРАНИТЬ КАРТОЧКУ" Width="220" 
                                Height="45" Margin="5,0" 
                                Background="{StaticResource SecondaryYellow}" 
                                Foreground="Black" 
                                FontWeight="Bold" 
                                BorderThickness="2" 
                                BorderBrush="{StaticResource PrimaryPink}" 
                                Command="{Binding SaveCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>