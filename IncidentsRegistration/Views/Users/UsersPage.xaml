<Page x:Class="IncidentsRegistration.Views.UsersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      Background="Transparent" Title="Пользователи">

    <Page.Resources>
        <DrawingBrush x:Key="BackgroundPatternBrush" TileMode="Tile" Viewport="0,0,100,100" ViewportUnits="Absolute" Opacity="0.1">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="{StaticResource SecondaryYellow}">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="10,10,20,20"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="{StaticResource PrimaryPink}">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="50,40,15,15"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="{StaticResource SecondaryBlue}">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="20,70,25,25"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <Style x:Key="IncidentItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="SelectionBorder" 
                                Background="Transparent" 
                                BorderBrush="Transparent" 
                                BorderThickness="3" 
                                Margin="0,0,0,12">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="SelectionBorder" Property="BorderBrush" Value="{StaticResource SecondaryYellow}"/>
                                <Setter TargetName="SelectionBorder" Property="Background" Value="#15FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource PrimaryGreen}">
        <Rectangle Fill="{StaticResource BackgroundPatternBrush}" />

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,25">
                <TextBlock Text="АДМИНИСТРИРОВАНИЕ" FontSize="11" FontWeight="Bold" Foreground="Black"/>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <Border Background="{StaticResource SecondaryYellow}" Width="8" Height="30" Margin="0,0,15,0"/>
                    <TextBlock Text="Учетные записи" FontSize="28" FontWeight="Bold" Foreground="Black"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
                <Button Content="ДОБАВИТЬ" Command="{Binding AddCommand}" 
                        Height="40" Padding="20,0" 
                        Background="{StaticResource SecondaryBlue}" 
                        BorderBrush="{StaticResource PrimaryPink}" 
                        BorderThickness="2" FontWeight="Bold" Foreground="Black"/>

                <Button Content="ИЗМЕНИТЬ" Command="{Binding UpdateCommand}" 
                        Height="40" Padding="20,0" Margin="10,0" 
                        Background="{StaticResource SecondaryYellow}" 
                        BorderBrush="{StaticResource PrimaryPink}" 
                        BorderThickness="2" FontWeight="Bold" Foreground="Black"/>

                <Button Content="УДАЛИТЬ" Command="{Binding DeleteCommand}" 
                        Height="40" Padding="20,0" 
                        Background="{StaticResource PrimaryPink}" 
                        BorderBrush="{StaticResource PrimaryPink}" 
                        BorderThickness="2" FontWeight="Bold" Foreground="Black"/>
            </StackPanel>

            <ListBox Grid.Row="2" 
                     ItemsSource="{Binding Users}" 
                     SelectedItem="{Binding SelectedUser}" 
                     Background="Transparent" 
                     BorderThickness="0"
                     HorizontalContentAlignment="Stretch"
                     ItemContainerStyle="{StaticResource IncidentItemStyle}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource SecondaryBlue}" BorderBrush="{StaticResource PrimaryPink}" BorderThickness="2" Padding="18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding LoginName}" FontSize="18" FontWeight="Bold" Foreground="Black"/>
                                    <Border Background="{StaticResource SecondaryYellow}" HorizontalAlignment="Left" Padding="8,2" Margin="0,5,0,0">
                                        <TextBlock Text="{Binding UserRole}" FontSize="11" FontWeight="Bold" Foreground="Black"/>
                                    </Border>
                                </StackPanel>

                                <Border Grid.Column="1" Background="{StaticResource PrimaryPink}" Width="40" Height="4" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Grid>
</Page>