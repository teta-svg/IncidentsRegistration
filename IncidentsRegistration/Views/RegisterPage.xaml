<Page x:Class="IncidentsRegistration.Views.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F0F2F5" Title="Регистрация">

    <Page.Resources>
        <Style x:Key="EntryField" TargetType="Control">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Control">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="1" CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="5,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#8B959E"/>
            <Setter Property="Margin" Value="5,15,0,5"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Ellipse Fill="{StaticResource SecondaryBlue}" Width="600" Height="600" Margin="-300,-300,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Opacity="0.5"/>

        <Border Background="White" 
                CornerRadius="25" 
                Padding="40,30" 
                Width="400" 
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.1"/>
            </Border.Effect>

            <StackPanel>
                <Border Background="{StaticResource SecondaryYellow}" 
                        Width="60" Height="60" CornerRadius="30" Margin="0,0,0,20">
                    <TextBlock Text="📝" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="Создание аккаунта" 
                           FontSize="24" 
                           FontWeight="SemiBold" 
                           Foreground="#2D3436" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,5"/>

                <TextBlock Text="Заполните данные для регистрации" 
                           FontSize="12" 
                           Foreground="#8B959E" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,10"/>

                <TextBlock Text="Логин" Style="{StaticResource LabelStyle}"/>
                <TextBox Text="{Binding Login}" Style="{StaticResource EntryField}"/>

                <TextBlock Text="Пароль" Style="{StaticResource LabelStyle}"/>
                <PasswordBox x:Name="PasswordBox" Style="{StaticResource EntryField}"/>

                <TextBlock Text="Подтвердите пароль" Style="{StaticResource LabelStyle}"/>
                <PasswordBox x:Name="ConfirmPasswordBox" Style="{StaticResource EntryField}"/>

                <Button Content="ЗАРЕГИСТРИРОВАТЬСЯ"
                        Height="50"
                        Background="{StaticResource PrimaryGreen}"
                        Foreground="#2D4A3E"
                        FontWeight="Bold"
                        Margin="0,35,0,12"
                        Click="Register_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="15"/>
                        </Style>
                    </Button.Resources>
                    <Button.Effect>
                        <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.2"/>
                    </Button.Effect>
                </Button>

                <Button Content="Уже есть аккаунт? Войти"
                        Background="Transparent"
                        Foreground="#8B959E"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="Back_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
