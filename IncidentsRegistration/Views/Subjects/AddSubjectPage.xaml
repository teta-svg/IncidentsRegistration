<Page x:Class="IncidentsRegistration.Views.AddSubjectPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      Background="Transparent"
      Title="Регистрация участника">

    <Page.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,10"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryPink}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Margin" Value="0,12,0,6"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryPink}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <Grid>

        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,25">
                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <Border Background="{StaticResource SecondaryYellow}" Width="8" Height="30" Margin="0,0,15,0"/>
                    <TextBlock Text="Регистрация участника" FontSize="28" FontWeight="Bold" Foreground="Black"/>
                </StackPanel>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Background="{StaticResource SecondaryBlue}" BorderBrush="{StaticResource PrimaryPink}" BorderThickness="2" Padding="25" Margin="0,0,0,20">
                        <StackPanel>
                            <Border Background="{StaticResource PrimaryPink}" Padding="10,4" HorizontalAlignment="Left" Margin="0,0,0,15">
                                <TextBlock Text="ПЕРСОНАЛЬНЫЕ ДАННЫЕ" Foreground="Black" FontWeight="Bold" FontSize="10"/>
                            </Border>

                            <StackPanel Visibility="{Binding RoleSelectionVisibility}">
                                <TextBlock Text="Роль в инциденте" Style="{StaticResource LabelStyle}"/>
                                <ComboBox ItemsSource="{Binding Roles}" SelectedItem="{Binding SelectedRole}"/>
                            </StackPanel>

                            <TextBlock Text="Фамилия" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding CurrentSubject.LastName}"/>

                            <UniformGrid Columns="2">
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Имя" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Text="{Binding CurrentSubject.FirstName}"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Отчество" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Text="{Binding CurrentSubject.Patronymic}"/>
                                </StackPanel>
                            </UniformGrid>

                            <TextBlock Text="Количество судимостей" Style="{StaticResource LabelStyle}"/>
                            <TextBox Width="120" HorizontalAlignment="Left" 
                                     Text="{Binding ConvictionsCount}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource SecondaryBlue}" 
                            BorderBrush="{StaticResource PrimaryPink}" 
                            BorderThickness="2" Padding="25" Margin="0,0,0,20">
                        <StackPanel>
                            <Border Background="{StaticResource SecondaryYellow}" 
                                    Padding="10,4" HorizontalAlignment="Left" Margin="0,0,0,15">
                                <TextBlock Text="АДРЕС ПРОЖИВАНИЯ" Foreground="Black" FontWeight="Bold" FontSize="10"/>
                            </Border>

                            <TextBlock Text="Населенный пункт" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding CurrentSubject.Settlement}"/>

                            <TextBlock Text="Улица" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding CurrentSubject.Street}"/>

                            <UniformGrid Columns="2">
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Дом" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Text="{Binding CurrentSubject.House}"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Квартира" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Text="{Binding CurrentSubject.Room}"/>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource PrimaryPink}"
                           Background="{StaticResource SecondaryYellow}"
                           FontSize="14"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,20"/>

            <Border Grid.Row="2" Background="{StaticResource PrimaryGreen}" 
                    BorderBrush="{StaticResource PrimaryPink}" 
                    BorderThickness="2" Padding="12" Margin="0,15,0,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="ОТМЕНИТЬ" 
                                Width="140" Height="45" 
                                Margin="5,0" 
                                Background="{StaticResource SecondaryBlue}" 
                                Foreground="Black" 
                                BorderThickness="2" 
                                BorderBrush="{StaticResource PrimaryPink}" 
                                FontWeight="Bold" 
                                 Command="{Binding BackCommand}" />

                        <Button Content="{Binding ButtonText}" 
                                Command="{Binding SaveCommand}" 
                                Width="220" Height="45" 
                                Margin="5,0"
                                Background="{StaticResource SecondaryYellow}" 
                                Foreground="Black" 
                                FontWeight="Bold" 
                                BorderThickness="2" 
                                BorderBrush="{StaticResource PrimaryPink}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>