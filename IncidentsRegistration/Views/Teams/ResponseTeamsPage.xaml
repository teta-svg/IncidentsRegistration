<Page x:Class="IncidentsRegistration.Views.ResponseTeamsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      Background="Transparent" Title="Группы реагирования">

    <Page.Resources>
        <DrawingBrush x:Key="BackgroundPatternBrush" TileMode="Tile" Viewport="0,0,100,100" ViewportUnits="Absolute" Opacity="0.1">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="{StaticResource SecondaryYellow}">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="10,10,20,20"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="{StaticResource PrimaryPink}">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="50,40,15,15"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="{StaticResource SecondaryBlue}">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="20,70,25,25"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <Style x:Key="IncidentItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="SelectionBorder" 
                                Background="Transparent" 
                                BorderBrush="Transparent" 
                                BorderThickness="3" 
                                Margin="0,0,0,12">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="SelectionBorder" Property="BorderBrush" Value="{StaticResource SecondaryYellow}"/>
                                <Setter TargetName="SelectionBorder" Property="Background" Value="#15FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource PrimaryGreen}">
        <Rectangle Fill="{StaticResource BackgroundPatternBrush}" />

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,25">
                <TextBlock Text="УПРАВЛЕНИЕ ПЕРСОНАЛОМ" FontSize="11" FontWeight="Bold" Foreground="Black"/>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <Border Background="{StaticResource SecondaryYellow}" Width="8" Height="30" Margin="0,0,15,0"/>
                    <TextBlock Text="Группы реагирования" FontSize="28" FontWeight="Bold" Foreground="Black"/>
                </StackPanel>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <Border Background="White" BorderThickness="2" BorderBrush="{StaticResource PrimaryPink}" Padding="10,2" Width="250">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🔍" VerticalAlignment="Center" Margin="5,0,10,0" Foreground="Black"/>
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" Foreground="Black" FontWeight="Medium"/>
                        </Grid>
                    </Border>

                    <Button Content="ИЗМЕНИТЬ" Command="{Binding UpdateCommand}" 
                            Margin="15,0,5,0" Padding="15,0" Height="40" 
                            Background="{StaticResource SecondaryYellow}" 
                            BorderBrush="{StaticResource PrimaryPink}" 
                            BorderThickness="2" FontWeight="Bold" Foreground="Black"/>

                    <Button Content="УДАЛИТЬ" Command="{Binding DeleteCommand}" 
                            Padding="15,0" Height="40" 
                            Background="{StaticResource PrimaryPink}" 
                            BorderBrush="{StaticResource PrimaryPink}" 
                            BorderThickness="2" FontWeight="Bold" Foreground="Black"/>
                </StackPanel>

                <Button Grid.Column="1" Content="НОВАЯ ГРУППА" Command="{Binding AddCommand}"
                        Background="{StaticResource SecondaryBlue}" Foreground="Black" 
                        Padding="20,0" Height="40" FontWeight="Bold"
                        BorderBrush="{StaticResource PrimaryPink}" BorderThickness="2"/>
            </Grid>

            <ListBox Grid.Row="2" 
                     ItemsSource="{Binding ResponseTeams}" 
                     SelectedItem="{Binding SelectedResponseTeam}"
                     Background="Transparent" 
                     BorderThickness="0" 
                     HorizontalContentAlignment="Stretch"
                     ItemContainerStyle="{StaticResource IncidentItemStyle}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource SecondaryBlue}" BorderBrush="{StaticResource PrimaryPink}" BorderThickness="2" Padding="18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding NameTeam}" FontSize="18" FontWeight="Bold" Foreground="Black"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <TextBlock Text="РУКОВОДИТЕЛЬ: " Foreground="Black" FontSize="11" FontWeight="Bold" Opacity="0.7"/>
                                        <TextBlock Foreground="Black" FontWeight="Medium" FontSize="13">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0} {1} {2}">
                                                    <Binding Path="DirectorLastName"/>
                                                    <Binding Path="DirectorFirstName"/>
                                                    <Binding Path="DirectorPatronymic"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock Text="{Binding NumberOfPeople, StringFormat='СОСТАВ: {0} ЧЕЛ.'}" Foreground="Black" FontSize="11" FontWeight="Bold" Opacity="0.7" Margin="0,2,0,0"/>
                                </StackPanel>

                                <Border Grid.Column="1" Background="{StaticResource SecondaryYellow}" Width="40" Height="4" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Grid>
</Page>