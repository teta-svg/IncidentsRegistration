<Page x:Class="IncidentsRegistration.Views.ResponseTeamEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      Background="Transparent" Title="Конфигурация группы">

    <Page.Resources>
        <DrawingBrush x:Key="BackgroundPatternBrush" TileMode="Tile" Viewport="0,0,100,100" ViewportUnits="Absolute" Opacity="0.1">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="{StaticResource SecondaryYellow}">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="10,10,20,20"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="{StaticResource PrimaryPink}">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="50,40,15,15"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="{StaticResource SecondaryBlue}">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="20,70,25,25"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Opacity" Value="0.7"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryPink}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource PrimaryGreen}">
        <Rectangle Fill="{StaticResource BackgroundPatternBrush}" />

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,25">
                <Button Content="← НАЗАД К СПИСКУ" Command="{Binding BackCommand}" 
                        Background="Transparent" BorderThickness="0" Foreground="Black" 
                        FontWeight="Bold" FontSize="10" HorizontalAlignment="Left" Cursor="Hand" Margin="0,0,0,10"/>
                <TextBlock Text="КОНФИГУРАЦИЯ ГРУППЫ" FontSize="11" FontWeight="Bold" Foreground="Black"/>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <Border Background="{StaticResource SecondaryYellow}" Width="8" Height="30" Margin="0,0,15,0"/>
                    <TextBlock Text="{Binding PageHeader}" FontSize="28" FontWeight="Bold" Foreground="Black"/>
                </StackPanel>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Background="{StaticResource SecondaryBlue}" BorderBrush="{StaticResource PrimaryPink}" BorderThickness="2" Padding="25" Margin="0,0,0,20">
                        <StackPanel>
                            <Border Background="{StaticResource SecondaryYellow}" Padding="12,5" HorizontalAlignment="Left" Margin="0,0,0,15">
                                <TextBlock Text="ОБЩИЕ СВЕДЕНИЯ" Foreground="Black" FontWeight="Bold" FontSize="10"/>
                            </Border>

                            <TextBlock Text="НАЗВАНИЕ КОМАНДЫ" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding CurrentTeam.NameTeam}" Height="40"/>

                            <TextBlock Text="КОЛИЧЕСТВО СОТРУДНИКОВ" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding CurrentTeam.NumberOfPeople}" Height="40" Width="120" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource SecondaryBlue}" BorderBrush="{StaticResource PrimaryPink}" BorderThickness="2" Padding="25" Margin="0,0,0,20">
                        <StackPanel>
                            <Border Background="{StaticResource PrimaryPink}" Padding="12,5" HorizontalAlignment="Left" Margin="0,0,0,15">
                                <TextBlock Text="ДАННЫЕ РУКОВОДИТЕЛЯ" Foreground="Black" FontWeight="Bold" FontSize="10"/>
                            </Border>

                            <TextBlock Text="ФАМИЛИЯ" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding CurrentTeam.DirectorLastName}" Height="40"/>

                            <UniformGrid Columns="2" Margin="0,5,0,0">
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="ИМЯ" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Text="{Binding CurrentTeam.DirectorFirstName}" Height="40"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="ОТЧЕСТВО" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Text="{Binding CurrentTeam.DirectorPatronymic}" Height="40"/>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="{StaticResource PrimaryGreen}" BorderBrush="{StaticResource PrimaryPink}" BorderThickness="2" Padding="12" Margin="0,15,0,0">
                <Grid>
                    <Button Content="НАЗАД" Command="{Binding BackCommand}" Height="40" Width="120" HorizontalAlignment="Left" Background="{StaticResource SecondaryBlue}" Foreground="Black" 
                            BorderBrush="{StaticResource PrimaryPink}" BorderThickness="2"
                            FontWeight="Bold" FontSize="12"/>
                    <Button Content="СОХРАНИТЬ ИЗМЕНЕНИЯ" Command="{Binding SaveCommand}" Height="40" Width="220" HorizontalAlignment="Right"
                            Background="{StaticResource SecondaryYellow}" Foreground="Black" 
                            BorderBrush="{StaticResource PrimaryPink}" BorderThickness="2" FontWeight="Bold" FontSize="12"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>