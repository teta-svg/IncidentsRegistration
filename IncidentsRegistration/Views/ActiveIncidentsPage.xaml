<Page x:Class="IncidentsRegistration.Views.ActiveIncidentsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Активные инциденты">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Border BorderThickness="1" CornerRadius="5" Width="60" Height="60">
                <TextBlock FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Активные инциденты" 
                       FontSize="26"
                       VerticalAlignment="Center" 
                       Margin="20,0"/>
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="Black" BorderThickness="2" CornerRadius="2" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Список активных инцидентов" FontWeight="Bold" Margin="0,0,0,10"/>

                <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding ActiveIncidents}"
                  SelectedItem="{Binding SelectedIncident}"
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  VerticalAlignment="Top" 
                  BorderBrush="Black" 
                  BorderThickness="1" 
                  Background="White"
                  GridLinesVisibility="All"
                  HorizontalGridLinesBrush="Black"
                  VerticalGridLinesBrush="Black">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding IdIncident}" Width="Auto"/>
                        <DataGridTextColumn Header="Группа" Binding="{Binding IdResponseTeamNavigation.NameTeam}" Width="Auto"/>
                        <DataGridTextColumn Header="Тип происшествия" Binding="{Binding TypeOfIncident}" Width="*"/>
                        <DataGridTextColumn Header="Время" Binding="{Binding RegistrationTime, StringFormat=\{0:HH:mm\}}" Width="Auto"/>
                        <DataGridTextColumn Header="Дата" Binding="{Binding RegistrationDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="Auto"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="2" BorderBrush="Black" BorderThickness="2" Margin="0,20,0,0" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Действия" FontWeight="Bold" Margin="0,0,0,10"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="ПОДРОБНЕЕ" Width="150" Height="40" Margin="5,0" Background="{StaticResource PrimaryGreen}"/>
                    <Button Content="ВЫНЕСТИ РЕШЕНИЕ" Background="{StaticResource SecondaryYellow}" FontWeight="Bold" Width="180" Height="40" Margin="5,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
