<Page x:Class="IncidentsRegistration.Views.ActiveIncidentsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Активные инциденты">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Border BorderThickness="1" CornerRadius="5" Width="60" Height="60">
                <TextBlock FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Активные инциденты" 
                       FontSize="26"
                       VerticalAlignment="Center" 
                       Margin="20,0"/>
        </StackPanel>

        <GroupBox Header="Список активных инцидентов" Grid.Row="1" Padding="5">
            <DataGrid ItemsSource="{Binding ActiveIncidents}"
                      SelectedItem="{Binding SelectedIncident}"
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding IdIncident}" Width="Auto"/>
                    <DataGridTextColumn Header="Группа" Binding="{Binding IdResponseTeamNavigation.NameTeam}" Width="Auto"/>
                    <DataGridTextColumn Header="Тип происшествия" Binding="{Binding TypeOfIncident}" Width="*"/>
                    <DataGridTextColumn Header="Время" Binding="{Binding RegistrationTime, StringFormat=\{0:HH:mm\}}" Width="Auto"/>
                    <DataGridTextColumn Header="Дата" Binding="{Binding RegistrationDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="Auto"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <GroupBox Header="Действия" Grid.Row="2" Margin="0,20,0,0" Padding="15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                <Button Content="ПОДРОБНЕЕ" 
                        Command="{Binding DetailsCommand}"
                        Width="150" Height="40" Margin="5,0"/>

                <Button Content="ВЫНЕСТИ РЕШЕНИЕ" 
                        Command="{Binding AddDecisionCommand}"
                        Background="#DCEDC8"
                        FontWeight="Bold"
                        Width="180" Height="40" Margin="5,0"/>

            </StackPanel>
        </GroupBox>
    </Grid>
</Page>
