<Page x:Class="IncidentsRegistration.Views.ActiveIncidentsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F0F2F5" Title="Активные инциденты">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="СИСТЕМА РЕГИСТРАЦИИ" FontSize="11" FontWeight="Bold" Foreground="#8B959E"/>
            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <Border Background="{StaticResource PrimaryGreen}" Width="8" Height="30" CornerRadius="4" Margin="0,0,15,0"/>
                <TextBlock Text="Активные инциденты" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#2D3436"/>
            </StackPanel>
        </StackPanel>

        <ListBox Grid.Row="1" 
                 ItemsSource="{Binding ActiveIncidents}"
                 SelectedItem="{Binding SelectedIncident}"
                 Background="Transparent" 
                 BorderThickness="0"
                 VirtualizingStackPanel.IsVirtualizing="True">

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border x:Name="CardBorder" Background="White" CornerRadius="15" Margin="0,0,0,12" Padding="20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.08"/>
                        </Border.Effect>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="{StaticResource SecondaryBlue}" CornerRadius="10" Padding="10,5" VerticalAlignment="Center">
                                <TextBlock Text="{Binding RegistrationTime, StringFormat=\{0:HH:mm\}}" FontWeight="Bold" Foreground="#4A90E2"/>
                            </Border>

                            <StackPanel Grid.Column="1" Margin="20,0">
                                <TextBlock Text="{Binding TypeOfIncident}" FontSize="16" FontWeight="Bold" Foreground="#2D3436"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="ID: " Foreground="#A0A0A0"/>
                                    <TextBlock Text="{Binding IdIncident}" Foreground="#636E72" Margin="0,0,15,0"/>
                                    <TextBlock Text="Команда: " Foreground="#A0A0A0"/>
                                    <TextBlock Text="{Binding IdResponseTeamNavigation.NameTeam}" Foreground="#636E72" FontWeight="Medium"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding RegistrationDate, StringFormat=\{0:dd MMM yyyy\}}" Foreground="#8B959E" FontSize="12" HorizontalAlignment="Right"/>
                                <Border Background="{StaticResource PrimaryPink}" CornerRadius="5" Height="5" Width="40" Margin="0,8,0,0" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                            <Setter TargetName="CardBorder" Property="BorderBrush" Value="{StaticResource PrimaryGreen}"/>
                            <Setter TargetName="CardBorder" Property="BorderThickness" Value="2"/>
                            <Setter TargetName="CardBorder" Property="Background" Value="#F9FDFB"/>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Row="2" Background="White" CornerRadius="20" Padding="15" Margin="0,15,0,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.05"/>
            </Border.Effect>
            <Grid>
                <TextBlock Text="Выберите инцидент из списка для принятия решения" 
                           VerticalAlignment="Center" Foreground="#A0A0A0" FontStyle="Italic" Margin="10,0"/>

                <Button Content="ВЫНЕСТИ РЕШЕНИЕ" 
                        Command="{Binding MakeDecisionCommand}" 
                        Background="{StaticResource SecondaryYellow}" 
                        FontWeight="Bold" Foreground="#5D5B1A"
                        Width="220" Height="45" HorizontalAlignment="Right">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="12"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Page>
