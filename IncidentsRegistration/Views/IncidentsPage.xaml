<Page x:Class="IncidentsRegistration.Views.IncidentsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Регистрация инцидентов"
      Background="#F0F2F5">

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">

            <TextBlock Text="АРХИВ И УПРАВЛЕНИЕ"
                       FontSize="11"
                       FontWeight="Bold"
                       Foreground="#8B959E"/>

            <StackPanel Orientation="Horizontal"
                        Margin="0,5,0,0">

                <Border Background="{StaticResource PrimaryPink}"
                        Width="8"
                        Height="30"
                        CornerRadius="4"
                        Margin="0,0,15,0"/>

                <TextBlock Text="Регистрация инцидентов"
                           FontSize="28"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="#2D3436"/>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="1"
              Margin="0,20,0,15">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">

                <StackPanel.Resources>

                    <Style TargetType="RadioButton">

                        <Setter Property="GroupName"
                    Value="SortGroup"/>

                        <Setter Property="Margin"
                    Value="0,0,8,0"/>

                        <Setter Property="Template">

                            <Setter.Value>

                                <ControlTemplate TargetType="RadioButton">

                                    <Border x:Name="btn"
                                Background="White"
                                CornerRadius="8"
                                Padding="12,6"
                                BorderThickness="1"
                                BorderBrush="#E9ECEF">

                                        <ContentPresenter/>

                                    </Border>

                                    <ControlTemplate.Triggers>

                                        <Trigger Property="IsChecked"
                                     Value="True">

                                            <Setter TargetName="btn"
                                        Property="Background"
                                        Value="{StaticResource SecondaryBlue}"/>

                                            <Setter TargetName="btn"
                                        Property="BorderBrush"
                                        Value="#4A90E2"/>

                                        </Trigger>

                                    </ControlTemplate.Triggers>

                                </ControlTemplate>

                            </Setter.Value>

                        </Setter>

                    </Style>

                </StackPanel.Resources>

                <TextBlock Text="Сортировать по:"
               VerticalAlignment="Center"
               Foreground="#8B959E"
               Margin="0,0,10,0"
               FontSize="12"/>

                <RadioButton Content="Времени"
                 IsChecked="True"
                 Click="SortByTime_Click"/>

                <RadioButton Content="Типу"
                 Click="SortByType_Click"/>

                <RadioButton Content="Группе"
                 Click="SortByTeam_Click"/>

            </StackPanel>

            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="10"
                    BorderThickness="1"
                    BorderBrush="#E9ECEF"
                    Padding="10,2">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="🔍"
                               VerticalAlignment="Center"
                               Margin="5,0,10,0"
                               Foreground="#ADB5BD"/>

                    <TextBox x:Name="SearchBox"
                             Grid.Column="1"
                             BorderThickness="0"
                             Background="Transparent"
                             VerticalAlignment="Center"
                             TextChanged="SearchBox_TextChanged"/>

                    <TextBlock Grid.Column="1"
                               Text="Поиск по типу..."
                               Margin="2,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="#ADB5BD"
                               IsHitTestVisible="False">

                        <TextBlock.Style>

                            <Style TargetType="TextBlock">

                                <Setter Property="Visibility"
                                        Value="Collapsed"/>

                                <Style.Triggers>

                                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}"
                                                 Value="">

                                        <Setter Property="Visibility"
                                                Value="Visible"/>

                                    </DataTrigger>

                                </Style.Triggers>

                            </Style>

                        </TextBlock.Style>

                    </TextBlock>

                </Grid>

            </Border>

        </Grid>

        <ListBox Grid.Row="2"
                 ItemsSource="{Binding Incidents}"
                 SelectedItem="{Binding SelectedIncident}"
                 Background="Transparent"
                 BorderThickness="0"
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">

            <ListBox.ItemContainerStyle>

                <Style TargetType="ListBoxItem">

                    <Setter Property="Template">

                        <Setter.Value>

                            <ControlTemplate TargetType="ListBoxItem">

                                <ContentPresenter/>

                            </ControlTemplate>

                        </Setter.Value>

                    </Setter>

                </Style>

            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>

                <DataTemplate>

                    <Border x:Name="CardBorder"
                            Background="White"
                            CornerRadius="15"
                            Margin="0,0,0,12"
                            Padding="18">

                        <Border.Effect>

                            <DropShadowEffect BlurRadius="8"
                                              ShadowDepth="1"
                                              Opacity="0.04"/>

                        </Border.Effect>

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                        VerticalAlignment="Center">

                                <Border Background="{StaticResource SecondaryBlue}"
                                        CornerRadius="8"
                                        Padding="10,4">

                                    <TextBlock Text="{Binding RegistrationTime, StringFormat=\{0:HH:mm\}}"
                                               FontWeight="Bold"
                                               Foreground="#4A90E2"/>

                                </Border>

                                <TextBlock Text="{Binding RegistrationDate, StringFormat=\{0:dd.MM.yy\}}"
                                           FontSize="10"
                                           Foreground="#ADB5BD"
                                           HorizontalAlignment="Center"
                                           Margin="0,4,0,0"/>

                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Margin="20,0">

                                <TextBlock Text="{Binding TypeOfIncident}"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#2D3436"/>

                                <StackPanel Orientation="Horizontal"
                                            Margin="0,4,0,0">

                                    <TextBlock Text="Группа: "
                                               Foreground="#A0A0A0"/>

                                    <TextBlock Text="{Binding IdResponseTeamNavigation.NameTeam}"
                                               Foreground="#636E72"
                                               FontWeight="Medium"/>

                                    <TextBlock Text=" • ID: "
                                               Margin="10,0,0,0"
                                               Foreground="#A0A0A0"/>

                                    <TextBlock Text="{Binding IdIncident}"
                                               Foreground="#636E72"/>

                                </StackPanel>

                            </StackPanel>

                            <Border Grid.Column="2"
                                    Background="#F8F9FA"
                                    CornerRadius="10"
                                    Padding="15,8"
                                    BorderThickness="1"
                                    BorderBrush="#E9ECEF"
                                    VerticalAlignment="Center">

                                <StackPanel Orientation="Horizontal">

                                    <Ellipse Width="8"
                                             Height="8"
                                             Fill="{StaticResource PrimaryGreen}"
                                             Margin="0,0,10,0"/>

                                    <TextBlock Text="{Binding Decision.DecisionType}"
                                               VerticalAlignment="Center"
                                               Foreground="#495057"
                                               FontWeight="Medium"/>

                                </StackPanel>

                            </Border>

                        </Grid>

                    </Border>

                    <DataTemplate.Triggers>

                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                     Value="True">

                            <Setter TargetName="CardBorder"
                                    Property="BorderBrush"
                                    Value="{StaticResource SecondaryBlue}"/>

                            <Setter TargetName="CardBorder"
                                    Property="BorderThickness"
                                    Value="2"/>

                            <Setter TargetName="CardBorder"
                                    Property="Background"
                                    Value="#FBFEFF"/>

                        </DataTrigger>

                    </DataTemplate.Triggers>

                </DataTemplate>

            </ListBox.ItemTemplate>

        </ListBox>

        <Border Grid.Row="3"
                Background="White"
                CornerRadius="20"
                Padding="12"
                Margin="0,15,0,0">

            <Border.Effect>

                <DropShadowEffect BlurRadius="8"
                                  ShadowDepth="0"
                                  Opacity="0.04"/>

            </Border.Effect>

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Управление записями инцидентов"
                           VerticalAlignment="Center"
                           Foreground="#A0A0A0"
                           Margin="15,0"
                           FontWeight="Medium"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">

                    <StackPanel.Resources>

                        <Style TargetType="Button">

                            <Setter Property="Height"
                                    Value="40"/>

                            <Setter Property="Width"
                                    Value="110"/>

                            <Setter Property="Margin"
                                    Value="5,0"/>

                            <Setter Property="FontWeight"
                                    Value="SemiBold"/>

                            <Setter Property="Template">

                                <Setter.Value>

                                    <ControlTemplate TargetType="Button">

                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="10">

                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>

                                        </Border>

                                    </ControlTemplate>

                                </Setter.Value>

                            </Setter>

                        </Style>

                    </StackPanel.Resources>

                    <Button Content="ПОДРОБНЕЕ"
                            Command="{Binding DetailsCommand}"
                            Background="{StaticResource SecondaryBlue}"
                            Foreground="#2C3E50"/>

                    <Button Content="ДОБАВИТЬ"
                            Command="{Binding AddCommand}"
                            Background="{StaticResource PrimaryGreen}"
                            Foreground="#2D4A3E"/>

                    <Button Content="ОБНОВИТЬ"
                            Command="{Binding UpdateCommand}"
                            Background="{StaticResource SecondaryYellow}"
                            Foreground="#5D5B1A"/>

                    <Button Content="УДАЛИТЬ"
                            Command="{Binding DeleteCommand}"
                            Background="{StaticResource PrimaryPink}"
                            Foreground="#5D2E32"/>

                </StackPanel>

            </Grid>

        </Border>

    </Grid>

</Page>