<Page x:Class="IncidentsRegistration.Views.IncidentsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Регистрация инцидентов">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Border BorderBrush="#CCC" BorderThickness="1" Width="60" Height="60">
                <!--Image Source="/Resources/logo_square.png" Stretch="Uniform"/-->
            </Border>
            <TextBlock Text="Регистрация инцидентов" 
                       FontSize="26" 
                       FontWeight="Light"
                       VerticalAlignment="Center" 
                       Margin="20,0"/>
        </StackPanel>

        <GroupBox Header="Текущие инциденты" Grid.Row="1" Padding="5">
            <DataGrid ItemsSource="{Binding Incidents}"
                      SelectedItem="{Binding SelectedIncident}"
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      BorderThickness="1"
                      BorderBrush="#DDD">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding IdIncident}" Width="Auto"/>

                    <DataGridTextColumn Header="Группа" Binding="{Binding IdResponseTeamNavigation.NameTeam}" Width="Auto"/>

                    <DataGridTextColumn Header="Тип происшествия" Binding="{Binding TypeOfIncident}" Width="*"/>

                    <DataGridTextColumn Header="Время" Binding="{Binding RegistrationTime, StringFormat=\{0:HH:mm\}}" Width="Auto"/>

                    <DataGridTextColumn Header="Дата" Binding="{Binding RegistrationDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="Auto"/>

                    <DataGridTextColumn Header="Статус решения" Binding="{Binding Decision.DecisionType}" Width="1.5*"/>
                </DataGrid.Columns>

            </DataGrid>
        </GroupBox>

        <GroupBox Header="Оперативные действия" Grid.Row="2" Margin="0,20,0,0" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                    <TextBlock Text="Выбор свободной группы:" 
                               Style="{StaticResource GroupHeader}"/>

                    <ComboBox ItemsSource="{Binding FreeResponseTeams}"
                              SelectedItem="{Binding SelectedResponseTeam}"
                              DisplayMemberPath="NameTeam"
                              Height="35"
                              VerticalContentAlignment="Center"
                              TabIndex="1"/>
                </StackPanel>

                <Button Grid.Column="1" 
                        Content="Назначить на инцидент" 
                        Command="{Binding AssignTeamCommand}"
                        VerticalAlignment="Bottom"
                        Height="35"
                        MinWidth="180"
                        TabIndex="2"/>
            </Grid>
        </GroupBox>
    </Grid>
</Page>
